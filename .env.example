# ─────────────────────────────────────────────────────────────────────────────
# IntelliCode Review — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend security ──────────────────────────────────────────────────────────
# Required to enable the /cache/clear endpoint.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=

# Optional: protect all endpoints (except /health) with an API key.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Pass via header: X-API-Key: <value>
INTELLICODE_API_KEY=

# ── After training: generate checkpoint integrity manifest ────────────────────
# Run once after every model training run to lock in SHA-256 hashes:
#   cd backend && python -m utils.checkpoint_integrity generate
# Commit checkpoints/manifest.json alongside the model files.

# ── GitHub OAuth (optional — enables GitHub repo scanning) ───────────────────
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# The callback URL you registered in your GitHub OAuth App settings
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback
# Where to redirect the user after OAuth completes
FRONTEND_URL=http://localhost:5173

# ── GitHub Webhook (optional — enables push/PR auto-analysis) ────────────────
# Set to the secret you configured in your GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=

# ── Weights & Biases experiment tracking (optional) ──────────────────────────
# Obtain from https://wandb.ai/settings
WANDB_API_KEY=

# ── Frontend (Vite build-time) ────────────────────────────────────────────────
# URL of the deployed backend — used during npm run build
# For local dev this is set automatically; only needed for production builds
VITE_API_URL=http://localhost:8000
